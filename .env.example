# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Get a free Hugging Face token at: https://huggingface.co/settings/tokens
# Create a token with "Read" permission — no credit card required.
HF_API_KEY=

# Vision provider — used for screenshot visual analysis.
# Priority: Anthropic → OpenAI → disabled (visual analyzer skipped if neither set).
# Get an Anthropic key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Get an OpenAI key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
